# Primer .env fajla za backend. Napraviti fajl ".env" sa pravim vrednostima.

# port na kom radi backend server
PORT=5000

# konekcija ka MongoDB bazi (lokalno preko Docker-a ili MongoDB Atlas u oblaku)
MONGO_URI=mongodb://localhost:27017/tracking

# tajni kljuc kojim se potpisuju JWT tokeni za prijavu
JWT_SECRET=promeni_me_u_neki_tajni_kljuc
